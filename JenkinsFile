pipeline {
    agent any

    stages {
        stage('Read Deployment Manifest') {
            steps {
                script {
                    manifest = readJSON file: 'deployment-manifest.json'
                    echo "Target Environment ID: ${manifest.environmentId}"
                    echo "Processes to deploy: ${manifest.processes.size()}"
                }
            }
        }

        stage('Package and Deploy Boomi Processes') {
            steps {
                script {
                    manifest.processes.each { process ->

                        def componentId = process.componentId
                        def componentType = process.componentType ?: 'process'
                        def packageVersion = process.packageVersion.replace('${BUILD_NUMBER}', "${BUILD_NUMBER}")
                        def packageNotes = "Packaged and deployed from Jenkins build ${BUILD_NUMBER} for ${process.name}"

                        echo "Packaging process: ${process.name}"
                        echo "Component ID: ${componentId}"

                        withCredentials([
                            string(credentialsId: 'BOOMI_ACCOUNT_ID', variable: 'BOOMI_ACCOUNT_ID'),
                            string(credentialsId: 'BOOMI_USERNAME', variable: 'BOOMI_USERNAME'),
                            string(credentialsId: 'BOOMI_API_TOKEN', variable: 'BOOMI_API_TOKEN')
                        ]) {
                            bat """
                            curl --ssl-no-revoke --fail -X POST ^
                              -u "%BOOMI_USERNAME%:%BOOMI_API_TOKEN%" ^
                              -H "Content-Type: application/json" ^
                              -H "Accept: application/json" ^
                              -d "{\\"componentId\\":\\"${componentId}\\",\\"componentType\\":\\"${componentType}\\",\\"packageVersion\\":\\"${packageVersion}\\",\\"notes\\":\\"${packageNotes}\\"}" ^
                              "https://api.boomi.com/api/rest/v1/%BOOMI_ACCOUNT_ID%/PackagedComponent" ^
                              -o package-response.json
                            """
                        }

                        def response = readFile('package-response.json')
                        echo response

                        def matcher = response =~ /"packageId"\s*:\s*"([^"]+)"/

                        if (!matcher.find()) {
                            error "Could not find packageId for ${process.name}"
                        }

                        def newPackageId = matcher.group(1)
                        echo "New Package ID for ${process.name}: ${newPackageId}"

                        echo "Deploying process: ${process.name}"

                        withCredentials([
                            string(credentialsId: 'BOOMI_ACCOUNT_ID', variable: 'BOOMI_ACCOUNT_ID'),
                            string(credentialsId: 'BOOMI_USERNAME', variable: 'BOOMI_USERNAME'),
                            string(credentialsId: 'BOOMI_API_TOKEN', variable: 'BOOMI_API_TOKEN')
                        ]) {
                            bat """
                            curl --ssl-no-revoke --fail -X POST ^
                              -u "%BOOMI_USERNAME%:%BOOMI_API_TOKEN%" ^
                              -H "Content-Type: application/json" ^
                              -H "Accept: application/json" ^
                              -d "{\\"packageId\\":\\"${newPackageId}\\",\\"environmentId\\":\\"${manifest.environmentId}\\",\\"notes\\":\\"${packageNotes}\\"}" ^
                              "https://api.boomi.com/api/rest/v1/%BOOMI_ACCOUNT_ID%/DeployedPackage"
                            """
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo "All Boomi processes packaged and deployed successfully."
        }
        failure {
            echo "Boomi package/deployment failed. Check console output."
        }
    }
}