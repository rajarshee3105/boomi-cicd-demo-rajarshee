pipeline {
    agent any

    stages {
        stage('Read Deployment Manifest') {
            steps {
                script {
                    env.MANIFEST_TEXT = readFile('deploymentmanifest.json')
                }
            }
        }

        stage('Package and Deploy Components') {
            steps {
                script {
                    def manifest = readJSON text: env.MANIFEST_TEXT

                    manifest.processes.each { item ->
                        def componentId = item.componentId
                        def componentType = item.componentType
                        def packageVersion = item.packageVersion
                        def packageNotes = "Packaged and deployed from Jenkins build ${BUILD_NUMBER} for ${item.name}"

                        echo "Packaging: ${item.name}"
                        echo "Component Type: ${componentType}"

                        withCredentials([
                            string(credentialsId: 'BOOMI_ACCOUNT_ID', variable: 'BOOMI_ACCOUNT_ID'),
                            string(credentialsId: 'BOOMI_USERNAME', variable: 'BOOMI_USERNAME'),
                            string(credentialsId: 'BOOMI_API_TOKEN', variable: 'BOOMI_API_TOKEN')
                        ]) {
                            bat """
                            curl --ssl-no-revoke --fail --max-time 120 -X POST ^
                              -u "%BOOMI_USERNAME%:%BOOMI_API_TOKEN%" ^
                              -H "Content-Type: application/json" ^
                              -H "Accept: application/json" ^
                              -d "{\\"componentId\\":\\"${componentId}\\",\\"componentType\\":\\"${componentType}\\",\\"packageVersion\\":\\"${packageVersion}\\",\\"notes\\":\\"${packageNotes}\\"}" ^
                              "https://api.boomi.com/api/rest/v1/%BOOMI_ACCOUNT_ID%/PackagedComponent" ^
                              -o package-response.json
                            """
                        }

                        def packageResponseText = readFile('package-response.json')
                        echo packageResponseText

                        def packageResponse = readJSON text: packageResponseText
                        def packageId = packageResponse.packageId

                        if (!packageId) {
                            error "Package ID not found for ${item.name}"
                        }

                        echo "Package created for ${item.name}: ${packageId}"
                        echo "Deploying: ${item.name}"

                        withCredentials([
                            string(credentialsId: 'BOOMI_ACCOUNT_ID', variable: 'BOOMI_ACCOUNT_ID'),
                            string(credentialsId: 'BOOMI_USERNAME', variable: 'BOOMI_USERNAME'),
                            string(credentialsId: 'BOOMI_API_TOKEN', variable: 'BOOMI_API_TOKEN')
                        ]) {
                            bat """
                            curl --ssl-no-revoke --fail --max-time 120 -X POST ^
                              -u "%BOOMI_USERNAME%:%BOOMI_API_TOKEN%" ^
                              -H "Content-Type: application/json" ^
                              -H "Accept: application/json" ^
                              -d "{\\"packageId\\":\\"${packageId}\\",\\"environmentId\\":\\"${manifest.environmentId}\\",\\"notes\\":\\"${packageNotes}\\"}" ^
                              "https://api.boomi.com/api/rest/v1/%BOOMI_ACCOUNT_ID%/DeployedPackage" ^
                              -o deploy-response.json
                            """
                        }

                        def deployResponse = readFile('deploy-response.json')
                        echo deployResponse

                        echo "Deployment completed for ${item.name}"
                    }
                }
            }
        }
    }

    post {
        success {
            echo "All listed Boomi components packaged and deployed successfully."
        }
        failure {
            echo "Boomi package/deployment failed. Check console output."
        }
    }
}